      "parameters": {
        "jsCode": "const agora = new Date().getTime();\nconst cincoHoras = 10* 60 * 60 * 1000;\n\nconst resultado = [];\n\nfor (const item of items) {\n\n  const dataMensagem = new Date(item.json.timestamp).getTime();\n\n  if (\n    item.json.author.bot === true &&\n    (agora - dataMensagem >= cincoHoras)\n  ) {\n    resultado.push(item);\n  }\n\n}\n\nreturn resultado;"
