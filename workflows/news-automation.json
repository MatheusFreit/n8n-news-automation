    {
      "parameters": {
        "jsCode": "const itens = items;\n\nconst usd = itens[0].json;\nconst eur = itens[1].json;\n\nconst data = new Date(usd.data_hora_cotacao);\n\nconst dataFormatada =\ndata.toLocaleDateString('pt-BR') +\n' - ' +\ndata.toLocaleTimeString('pt-BR', {hour:'2-digit', minute:'2-digit'});\n\nconst mensagem = `\nOlá! 💰\n\nInformações da cotação do USD/EUR:\n\n📅 ${dataFormatada}\n\nUSD\n💵 Compra: R$ ${usd.cotacao_compra.toFixed(2)}\n💵 Venda: R$ ${usd.cotacao_venda.toFixed(2)}\n\nEUR\n💵 Compra: R$ ${eur.cotacao_compra.toFixed(2)}\n💵 Venda: R$ ${eur.cotacao_venda.toFixed(2)}\n\nFonte: BrasilAPI\n`;\n\nreturn [\n  {\n    json: {\n      mensagem\n    }\n  }\n];"
      },
