      "parameters": {
        "jsCode": "const maxPorCanal = 2; // Aqui você define o limite\nconst contador = {};\nconst resultado = [];\n\nfor (const item of items) {\n  // 1. Verificamos se o ID do canal existe (O \"IF\" de segurança)\n  let channelId = \"\";\n  \n  if (item.pairedItem && item.pairedItem.json && item.pairedItem.json.youtuber_id) {\n    channelId = item.pairedItem.json.youtuber_id;\n  } else {\n    // Fallback: Se o n8n se perder no pareamento, usamos o autor como ID\n    channelId = item.json.author || \"desconhecido\";\n  }\n\n  // 2. Inicializamos o contador para esse canal se ele for novo\n  if (!contador[channelId]) {\n    contador[channelId] = 0;\n  }\n\n  // 3. O \"IF\" principal: Verifica se ainda podemos pegar vídeos deste canal\n  if (contador[channelId] < maxPorCanal) {\n    resultado.push(item.json); // Adiciona o vídeo à lista de envio\n    contador[channelId]++;     // Sobe o contador: 1, 2... e para.\n  }\n}\n\nreturn resultado;"
      },
